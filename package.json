{
  "name": "burger-brothers-berlin",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "node server.js",
    "dev:next": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:health": "ts-node tools/db_health.ts",
    "migrate:json": "ts-node tools/migrate_json_to_db.ts",
    "vercel:dev": "vercel dev",
    "prepush": "npm run typecheck && npm run build",
    "bootstrap": "curl -X POST http://localhost:3000/api/bootstrap -H \"Content-Type: application/json\" -d @bootstrap.json",
    "security:test": "node tools/security-tests.mjs && node tools/security-regression-tests.mjs && node tools/middleware-access-tests.cjs && node tools/release-security-tests.mjs && node tools/session-security-tests.cjs && node tools/tv-login-route-tests.cjs && node tools/driver-security-tests.cjs && node tools/order-pricing-tests.cjs && node tools/order-access-security-tests.cjs && node tools/order-role-route-tests.cjs && node tools/order-claim-route-tests.cjs",
    "security:audit": "npm audit --audit-level=high",
    "verify": "npm run typecheck && npm run security:test && npm run build",
    "pricing:test": "node tools/order-pricing-tests.cjs",
    "session:test": "node tools/session-security-tests.cjs",
    "driver-security:test": "node tools/driver-security-tests.cjs",
    "release:test": "node tools/release-security-tests.mjs",
    "secure:release": "powershell -ExecutionPolicy Bypass -File tools/create-secure-release.ps1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@react-three/drei": "9.122.0",
    "@react-three/fiber": "^8.15.16",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "2.1.1",
    "howler": "^2.2.4",
    "jsbarcode": "^3.12.1",
    "lucide-react": "^0.545.0",
    "next": "15.5.20",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-qr-code": "^2.0.18",
    "stripe": "^22.3.1",
    "three": "^0.180.0",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "autoprefixer": "10.4.19",
    "local-ssl-proxy": "^2.0.5",
    "postcss": "8.5.19",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.10",
    "ts-node": "^10.9.2",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "brace-expansion": "2.0.3",
    "follow-redirects": "1.16.0",
    "minimatch": "9.0.7",
    "picomatch": "2.3.2",
    "uuid": "11.1.1",
    "yaml": "2.8.3",
    "glob": "10.5.0",
    "defu": "6.1.7",
    "postcss": "$postcss"
  }
}
