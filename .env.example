# Burger Brothers Berlin — safe environment template
# Copy to .env.local and set real values locally/Vercel. Never commit .env.local.

# PostgreSQL / tenant
DATABASE_URL=
DEFAULT_TENANT_SLUG=burger-brothers
DEFAULT_TENANT_NAME=Burger Brothers Berlin

# Signed sessions (minimum 32 random characters)
SESSION_SECRET=
ADMIN_USER=
ADMIN_PASS=
TV_PIN=

# One-time / server-to-server operations
BOOTSTRAP_MIGRATION_TOKEN=
CRON_SECRET=
PRINT_AGENT_TOKEN=
PRINT_PROXY_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Telegram order fallback (server-side only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ORDER_CHAT_ID=

# Public URLs
NEXT_PUBLIC_BASE_URL=https://www.burger-brothers.berlin
SITE_URL=https://www.burger-brothers.berlin

# Optional privacy / retention
ANALYTICS_IP_SECRET=
TRACKING_PUBLIC_TTL_HOURS=72
TRACKING_RETENTION_DAYS=7

# Optional print hardening
PRINT_TEST_ENABLED=false
PRINT_PROXY_HOST=127.0.0.1
PRINT_TEST_ALLOWED_PROXY_ORIGINS=
ORDER_URL_ORIGINS=https://www.burger-brothers.berlin
