# Yerel yazici proxy ayarlari. Bu dosyayi .env olarak kopyalayip degerleri duzenleyin.
PORT=7777
PRINT_PROXY_HOST=127.0.0.1
PRINTER_IP=192.168.0.150
PRINTER_PORT=9100

# Uygulamadaki PRINT_AGENT_TOKEN ile ayni, uzun ve rastgele bir deger kullanin.
PRINT_PROXY_TOKEN=BURAYA_UZUN_RASTGELE_TOKEN

ALLOW_ORIGINS=https://www.burger-brothers.berlin,http://127.0.0.1,http://localhost
ALLOW_ORDER_URL_RESOLUTION=0
ORDER_URL_ORIGINS=https://www.burger-brothers.berlin

LOGO_URL=https://www.burger-brothers.berlin/logo-thermal.bmp
ALLOW_INSECURE_LOGO=0
